MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_JS_API_KEY=

STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=php

TWILIO_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# -----------------------------------------------------------------------------
# Courier Integration (Phase 1 Shared Foundation)
# -----------------------------------------------------------------------------
# Local network switch guide:
# 1) FASTTRACK_BASE_URL: change host/port when FastTrack app runs elsewhere.
#    Same machine example: http://127.0.0.1:8001
#    LAN example:         http://192.168.1.50:8001
# 2) Keep *_PATH values as paths only (start with /), not full URLs.
# 3) If browser requests go cross-origin, update CORS in both applications.
# 4) Rotate API keys regularly for demos and never commit real secret values.

COURIER_PROVIDER_DEFAULT=fasttrack
COURIER_API_KEY_HEADER=X-Integration-Key
COURIER_CONNECT_TIMEOUT_SECONDS=5
COURIER_REQUEST_TIMEOUT_SECONDS=10
COURIER_MAX_RETRIES=1
COURIER_RETRY_SLEEP_MILLISECONDS=200

FASTTRACK_BASE_URL=http://127.0.0.1:8001
FASTTRACK_OUTBOUND_ORDER_PATH=/api/orders
FASTTRACK_STATUS_CALLBACK_PATH=/api/fasttrack/status-update
FASTTRACK_API_KEY=

# Explicit CORS allow-list for browser-based local demos across ports.
# Keep this comma-separated and update when switching to LAN IPs.
CORS_ALLOWED_ORIGINS=http://127.0.0.1:8000,http://127.0.0.1:8001,http://localhost:8000,http://localhost:8001
